{
    "name": "cesargb/key-value-store",
    "description": "A simple key-value store implementation in PHP.",
    "type": "library",
    "keywords": [ "key-value store"],
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Cesargb\\KeyValueStore\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Cesargb\\KeyValueStore\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.5",
        "phpstan/phpstan": "^2.1",
        "illuminate/database": "^12.0|^13.0"
    },
    "scripts": {
        "test": "./vendor/bin/phpunit"
    },
    "suggest": {
        "illuminate/database": "Required to use EloquentStore repository.",
        "ext-redis": "Required to use RedisStore repository.",
        "predis/predis": "Required to use PredisStore repository."
    },
    "extra": {
        "laravel": {
            "providers": [
                "Cesargb\\KeyValueStore\\Laravel\\KeyValueStoreServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
